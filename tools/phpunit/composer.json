{
  "repositories": [
    {
      "type": "package",
      "package": {
        "name": "project60/org.project60.sepa",
        "version": "dev-master",
        "source": {
          "url": "https://github.com/Project60/org.project60.sepa.git",
          "type": "git",
          "reference": "master"
        },
        "autoload": {
          "classmap": [
            ""
          ]
        }
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "symfony/phpunit-bridge": "^7",
    "systopia/civicrm-test-fixtures-sepa": "dev-main"
  },
  "scripts": {
    "post-install-cmd": [
      "@php vendor/bin/simple-phpunit install --configuration ../../phpunit.xml.dist"
    ],
    "post-update-cmd": [
      "@php vendor/bin/simple-phpunit install --configuration ../../phpunit.xml.dist"
    ]
  },
  "config": {
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "civicrm/composer-compile-plugin": true,
      "civicrm/composer-downloads-plugin": true
    },
    "sort-packages": true
  },
  "extra": {
    "compile-whitelist": [
      "civicrm/civicrm-core",
      "civicrm/composer-compile-lib"
    ]
  }
}
